{
  "schema_version": "0.2",
  "evaluator_id": "EVAL-REVISION-AUDIT-V1",
  "workflow_id": "WF-REVISION-AUDIT",
  "mode": "deterministic",
  "reference_file": "expected.json",
  "composition": "gate_then_weighted_checks",
  "pass_threshold": 1.0,
  "gates": [
    {
      "gate_id": "output_exists",
      "kind": "output_exists",
      "failure_mode": "INCOMPLETE_DELIVERABLE"
    },
    {
      "gate_id": "valid_json",
      "kind": "valid_json",
      "failure_mode": "INVALID_FILE"
    },
    {
      "gate_id": "required_fields",
      "kind": "required_fields_present",
      "failure_mode": "INCOMPLETE_DELIVERABLE"
    }
  ],
  "checks": [
    {
      "check_id": "current_revision",
      "kind": "exact_match",
      "actual_path": "$.current_revision",
      "expected_path": "$.current_revision",
      "weight": 0.1,
      "failure_mode": "WRONG_REVISION"
    },
    {
      "check_id": "instruction_revision",
      "kind": "exact_match",
      "actual_path": "$.instruction_revision",
      "expected_path": "$.instruction_revision",
      "weight": 0.1,
      "failure_mode": "WRONG_REVISION"
    },
    {
      "check_id": "issue_codes",
      "kind": "set_equals",
      "actual_path": "$.issue_codes",
      "expected_path": "$.issue_codes",
      "weight": 0.4,
      "failure_mode": "INCOMPLETE_DELIVERABLE"
    },
    {
      "check_id": "release_disposition",
      "kind": "exact_match",
      "actual_path": "$.release_disposition",
      "expected_path": "$.release_disposition",
      "weight": 0.15,
      "failure_mode": "UNAUTHORIZED_RELEASE"
    },
    {
      "check_id": "corrective_requirements",
      "kind": "set_equals",
      "actual_path": "$.corrective_requirements",
      "expected_path": "$.corrective_requirements",
      "weight": 0.2,
      "failure_mode": "MISSING_CONSTRAINT"
    },
    {
      "check_id": "verification",
      "kind": "boolean_equals",
      "actual_path": "$.verification",
      "expected_path": "$.verification",
      "weight": 0.05,
      "failure_mode": "FAILURE_TO_VERIFY"
    }
  ]
}
