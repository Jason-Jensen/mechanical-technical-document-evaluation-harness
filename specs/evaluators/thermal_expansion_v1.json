{
  "schema_version": "0.2",
  "evaluator_id": "EVAL-THERMAL-EXPANSION-V1",
  "workflow_id": "WF-THERMAL-EXPANSION",
  "mode": "deterministic",
  "reference_file": "expected.json",
  "composition": "gate_then_weighted_checks",
  "pass_threshold": 1.0,
  "gates": [
    {
      "gate_id": "output_exists",
      "kind": "output_exists",
      "failure_mode": "INCOMPLETE_DELIVERABLE"
    },
    {
      "gate_id": "valid_json",
      "kind": "valid_json",
      "failure_mode": "INVALID_FILE"
    },
    {
      "gate_id": "required_fields",
      "kind": "required_fields_present",
      "failure_mode": "INCOMPLETE_DELIVERABLE"
    },
    {
      "gate_id": "field_types",
      "kind": "field_types_match",
      "failure_mode": "INVALID_FILE"
    }
  ],
  "checks": [
    {
      "check_id": "temperature_change",
      "kind": "numeric_close",
      "actual_path": "$.temperature_change_c",
      "expected_path": "$.temperature_change_c",
      "absolute_tolerance": 0.01,
      "weight": 0.15,
      "failure_mode": "TEMPERATURE_DIFFERENCE_ERROR"
    },
    {
      "check_id": "free_expansion",
      "kind": "numeric_close",
      "actual_path": "$.free_expansion_mm",
      "expected_path": "$.free_expansion_mm",
      "absolute_tolerance": 0.01,
      "weight": 0.25,
      "failure_mode": "UNIT_ERROR"
    },
    {
      "check_id": "verification_expansion",
      "kind": "numeric_close",
      "actual_path": "$.verification_expansion_mm",
      "expected_path": "$.verification_expansion_mm",
      "absolute_tolerance": 0.01,
      "weight": 0.2,
      "failure_mode": "WRONG_FORMULA"
    },
    {
      "check_id": "relative_difference",
      "kind": "numeric_close",
      "actual_path": "$.relative_difference_percent",
      "expected_path": "$.relative_difference_percent",
      "absolute_tolerance": 0.01,
      "weight": 0.1,
      "failure_mode": "FAILURE_TO_VERIFY"
    },
    {
      "check_id": "expansion_direction",
      "kind": "exact_match",
      "actual_path": "$.expansion_direction",
      "expected_path": "$.expansion_direction",
      "weight": 0.1,
      "failure_mode": "SIGN_ERROR"
    },
    {
      "check_id": "calculation_disposition",
      "kind": "exact_match",
      "actual_path": "$.calculation_disposition",
      "expected_path": "$.calculation_disposition",
      "weight": 0.1,
      "failure_mode": "MISSING_CONSTRAINT"
    },
    {
      "check_id": "verification",
      "kind": "boolean_equals",
      "actual_path": "$.verification",
      "expected_path": "$.verification",
      "weight": 0.1,
      "failure_mode": "FAILURE_TO_VERIFY"
    }
  ]
}
