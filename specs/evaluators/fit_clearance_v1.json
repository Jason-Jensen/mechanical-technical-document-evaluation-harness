{
  "schema_version": "0.2",
  "evaluator_id": "EVAL-FIT-CLEARANCE-V1",
  "workflow_id": "WF-FIT-CLEARANCE",
  "mode": "deterministic",
  "reference_file": "expected.json",
  "composition": "gate_then_weighted_checks",
  "pass_threshold": 0.95,
  "gates": [
    {
      "gate_id": "output_exists",
      "kind": "output_exists",
      "failure_mode": "INCOMPLETE_DELIVERABLE"
    },
    {
      "gate_id": "valid_json",
      "kind": "valid_json",
      "failure_mode": "INVALID_FILE"
    },
    {
      "gate_id": "required_fields",
      "kind": "required_fields_present",
      "failure_mode": "INCOMPLETE_DELIVERABLE"
    }
  ],
  "checks": [
    {
      "check_id": "minimum_clearance",
      "kind": "numeric_close",
      "actual_path": "$.minimum_clearance_mm",
      "expected_path": "$.minimum_clearance_mm",
      "absolute_tolerance": 0.001,
      "weight": 0.2,
      "failure_mode": "RADIAL_DIAMETRAL_CONFUSION"
    },
    {
      "check_id": "maximum_clearance",
      "kind": "numeric_close",
      "actual_path": "$.maximum_clearance_mm",
      "expected_path": "$.maximum_clearance_mm",
      "absolute_tolerance": 0.001,
      "weight": 0.2,
      "failure_mode": "NUMERIC_ERROR"
    },
    {
      "check_id": "fit_type",
      "kind": "exact_match",
      "actual_path": "$.fit_type",
      "expected_path": "$.fit_type",
      "weight": 0.15,
      "failure_mode": "TABLE_MISREAD"
    },
    {
      "check_id": "measured_clearance",
      "kind": "numeric_close",
      "actual_path": "$.measured_clearance_mm",
      "expected_path": "$.measured_clearance_mm",
      "absolute_tolerance": 0.001,
      "weight": 0.2,
      "failure_mode": "NUMERIC_ERROR"
    },
    {
      "check_id": "disposition",
      "kind": "exact_match",
      "actual_path": "$.inspection_disposition",
      "expected_path": "$.inspection_disposition",
      "weight": 0.15,
      "failure_mode": "MISSING_CONSTRAINT"
    },
    {
      "check_id": "verification",
      "kind": "boolean_equals",
      "actual_path": "$.verification",
      "expected_path": "$.verification",
      "weight": 0.1,
      "failure_mode": "FAILURE_TO_VERIFY"
    }
  ]
}
