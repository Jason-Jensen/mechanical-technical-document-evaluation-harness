{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/candidate.schema.json",
  "title": "Candidate Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "candidate_id",
    "artifact_type",
    "artifacts",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "case_id": {
      "type": "string",
      "pattern": "^MECH-[0-9]{3}$"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "payload": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    }
  }
}