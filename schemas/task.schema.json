{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/task.schema.json",
  "title": "Task Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "workflow_id",
    "title",
    "instructions",
    "input_assets",
    "deliverable",
    "constraints"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_-]{2,63}$"
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_-]{2,63}$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "instructions": {
      "type": "string",
      "minLength": 30
    },
    "input_assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "media_type",
          "purpose"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_.\\-/]+$"
          },
          "media_type": {
            "type": "string",
            "minLength": 3
          },
          "purpose": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filename",
        "media_type",
        "description",
        "required_fields"
      ],
      "properties": {
        "filename": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_.\\-/]+$"
        },
        "media_type": {
          "type": "string",
          "enum": [
            "application/json",
            "text/markdown"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 15
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "human_review_required": {
      "type": "boolean",
      "const": true
    }
  }
}
