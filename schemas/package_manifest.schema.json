{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/package_manifest.schema.json",
  "title": "Mechanical Package Assurance Manifest v0.3.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "package_title",
    "created_date",
    "synthetic",
    "source_inventory",
    "authority_map_ref",
    "allowed_file_reference_roots",
    "document_inventory",
    "file_references",
    "relationship_declarations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.3.0"
    },
    "package_id": {
      "$ref": "#/$defs/canonicalIdentifier"
    },
    "package_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "created_date": {
      "type": "string",
      "format": "date"
    },
    "synthetic": {
      "type": "boolean"
    },
    "source_inventory": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "$ref": "#/$defs/sourceDeclaration"
      }
    },
    "authority_map_ref": {
      "$ref": "#/$defs/relativePath"
    },
    "allowed_file_reference_roots": {
      "const": [
        "files"
      ]
    },
    "document_inventory": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/documentDeclaration"
      }
    },
    "file_references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileReference"
      }
    },
    "relationship_declarations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationshipDeclaration"
      }
    }
  },
  "$defs": {
    "canonicalIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\u0000-\\u001F\\u007F]+$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!\\s)(?!.*\\s$)[^\\u0000-\\u001F\\u007F]+$"
    },
    "sourceDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "path",
        "format",
        "required_for_release"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "package_manifest",
            "drawing_register",
            "drawing_metadata",
            "bom_or_equipment_list",
            "datasheet_spec_metadata",
            "revision_history",
            "authority_map"
          ]
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "csv"
          ]
        },
        "required_for_release": {
          "const": true
        }
      }
    },
    "revisionDeclaration": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "revision_id",
            "scheme",
            "max_letters"
          ],
          "properties": {
            "revision_id": {
              "type": "string",
              "pattern": "^[A-Z]{1,3}$"
            },
            "scheme": {
              "const": "alpha_upper"
            },
            "max_letters": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "revision_id",
            "scheme"
          ],
          "properties": {
            "revision_id": {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            "scheme": {
              "const": "numeric_integer"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "revision_id",
            "scheme",
            "width"
          ],
          "properties": {
            "revision_id": {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            "scheme": {
              "const": "numeric_zero_padded"
            },
            "width": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "revision_id",
            "scheme",
            "allowed_values"
          ],
          "properties": {
            "revision_id": {
              "$ref": "#/$defs/canonicalIdentifier"
            },
            "scheme": {
              "const": "explicit_sequence"
            },
            "allowed_values": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/canonicalIdentifier"
              }
            }
          }
        }
      ]
    },
    "documentDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id",
        "document_type",
        "title",
        "required_for_release",
        "current_revision"
      ],
      "properties": {
        "document_id": {
          "$ref": "#/$defs/canonicalIdentifier"
        },
        "document_type": {
          "type": "string",
          "enum": [
            "drawing",
            "datasheet",
            "specification",
            "equipment_list",
            "register",
            "revision_record",
            "model",
            "other_controlled_document"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "required_for_release": {
          "type": "boolean"
        },
        "current_revision": {
          "$ref": "#/$defs/revisionDeclaration"
        },
        "drawing_number": {
          "$ref": "#/$defs/canonicalIdentifier"
        },
        "datasheet_id": {
          "$ref": "#/$defs/canonicalIdentifier"
        },
        "specification_id": {
          "$ref": "#/$defs/canonicalIdentifier"
        },
        "file_ref_id": {
          "$ref": "#/$defs/canonicalIdentifier"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "document_type": {
                "const": "drawing"
              }
            },
            "required": [
              "document_type"
            ]
          },
          "then": {
            "required": [
              "drawing_number"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "document_type": {
                "const": "datasheet"
              }
            },
            "required": [
              "document_type"
            ]
          },
          "then": {
            "required": [
              "datasheet_id"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "document_type": {
                "const": "specification"
              }
            },
            "required": [
              "document_type"
            ]
          },
          "then": {
            "required": [
              "specification_id"
            ]
          }
        }
      ]
    },
    "fileReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_ref_id",
        "path",
        "artifact_type",
        "required_for_release"
      ],
      "properties": {
        "file_ref_id": {
          "$ref": "#/$defs/canonicalIdentifier"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "artifact_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "required_for_release": {
          "type": "boolean"
        }
      }
    },
    "canonicalReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identifier_type",
        "identifier"
      ],
      "properties": {
        "identifier_type": {
          "type": "string",
          "enum": [
            "document_id",
            "drawing_number",
            "item_id",
            "equipment_tag",
            "datasheet_id",
            "specification_id",
            "file_ref_id"
          ]
        },
        "identifier": {
          "$ref": "#/$defs/canonicalIdentifier"
        }
      }
    },
    "relationshipDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relationship_id",
        "relationship_type",
        "source",
        "target",
        "required_for_release"
      ],
      "properties": {
        "relationship_id": {
          "$ref": "#/$defs/canonicalIdentifier"
        },
        "relationship_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "source": {
          "$ref": "#/$defs/canonicalReference"
        },
        "target": {
          "$ref": "#/$defs/canonicalReference"
        },
        "required_for_release": {
          "type": "boolean"
        }
      }
    }
  }
}
