{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/evaluator.schema.json",
  "title": "Evaluator Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluator_id",
    "workflow_id",
    "mode",
    "reference_file",
    "composition",
    "pass_threshold",
    "gates",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2"
    },
    "evaluator_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_-]{2,63}$"
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_-]{2,63}$"
    },
    "mode": {
      "type": "string",
      "const": "deterministic"
    },
    "reference_file": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_.\\-/]+$"
    },
    "composition": {
      "type": "string",
      "const": "gate_then_weighted_checks"
    },
    "pass_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate_id",
          "kind",
          "failure_mode"
        ],
        "properties": {
          "gate_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "output_exists",
              "valid_json",
              "required_fields_present"
            ]
          },
          "failure_mode": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_-]{2,63}$"
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "kind",
          "actual_path",
          "expected_path",
          "weight",
          "failure_mode"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "numeric_close",
              "exact_match",
              "set_equals",
              "boolean_equals",
              "contains_all"
            ]
          },
          "actual_path": {
            "type": "string",
            "pattern": "^\\$(?:\\.[A-Za-z_][A-Za-z0-9_]*)+$"
          },
          "expected_path": {
            "type": "string",
            "pattern": "^\\$(?:\\.[A-Za-z_][A-Za-z0-9_]*)+$"
          },
          "absolute_tolerance": {
            "type": "number",
            "minimum": 0
          },
          "weight": {
            "type": "number",
            "exclusiveMinimum": 0,
            "maximum": 1
          },
          "failure_mode": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_-]{2,63}$"
          }
        }
      }
    }
  }
}
